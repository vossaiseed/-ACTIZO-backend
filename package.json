{
  "name": "actizo-crm-backend",
  "version": "1.0.0",
  "private": true,
  "description": "ACTIZO CRM — backend API (Node.js + Express + Supabase)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon --exec \"node --use-system-ca\" src/server.js",
    "start": "node --use-system-ca src/server.js",
    "db:push": "node --use-system-ca src/db/runSql.js schema.sql",
    "db:seed": "node --use-system-ca src/db/seed.js",
    "db:check": "node --use-system-ca src/db/check.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "eslint": "^9.11.0",
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": ">=18"
  }
}
