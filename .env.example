# ---- Server ----
NODE_ENV=development
PORT=5000
API_PREFIX=/api
CORS_ORIGIN=http://localhost:5173

# ---- Supabase ----
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Public anon key (client-side safe)
SUPABASE_ANON_KEY=
# Service-role key (server only — bypasses RLS; NEVER expose to the frontend)
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string (Supabase → Project Settings → Database).
# Used by `npm run db:push` to apply schema.sql.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ---- Auth (JWT) ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_EXPIRES_IN=30d

# ---- Misc ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
